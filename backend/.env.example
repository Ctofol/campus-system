# 数据库配置
# PostgreSQL (推荐生产环境)
SQLALCHEMY_DATABASE_URL=postgresql://username:password@localhost:5432/campus_db

# SQLite (开发环境，默认)
# SQLALCHEMY_DATABASE_URL=sqlite:///./campus_sports.db

# JWT密钥（用于生成token）
SECRET_KEY=your-secret-key-here-change-in-production

# API配置
API_HOST=0.0.0.0
API_PORT=8000

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600  # 100MB

# 腾讯地图API Key（如果需要）
TENCENT_MAP_KEY=your-tencent-map-key
