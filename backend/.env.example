# 数据库配置
SQLALCHEMY_DATABASE_URL=postgresql://username:password@localhost:5432/campus_db

SECRET_KEY=your-secret-key-here-change-in-production

API_HOST=0.0.0.0
API_PORT=8000

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# 腾讯位置服务 WebService — 学生首页天气（服务端代理，Key 勿放前端）
# 与小程序 manifest 地图 Key 可共用；控制台须开启 WebServiceAPI + 天气服务
# 本项目应用「大学生运动健康平台」Key 示例：
TENCENT_MAP_KEY=ET4BZ-QJAL4-EMPUD-FBOLE-M23H3-3RBXD
# TENCENT_MAP_API_BASE=https://apis.map.qq.com
# WEATHER_CACHE_TTL_SEC=1800

# 人脸核验：none | local(InsightFace) | tencent
FACE_PROVIDER=local
# 本地 InsightFace（无需腾讯云密钥）
FACE_INSIGHTFACE_MODEL=buffalo_l
FACE_INSIGHTFACE_PROVIDERS=CPUExecutionProvider
FACE_LOCAL_MIN_SIMILARITY=0.42
# 腾讯云（仅 FACE_PROVIDER=tencent 时需要）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-guangzhou
FACE_MATCH_THRESHOLD=70
FACE_BLOCK_ON_FAIL=true

# 体测视频分析
TEST_ANALYSIS_USE_BACKGROUND=true
TEST_DEFAULT_MIN_COUNT=10
TEST_MIN_COUNT_PULL_UP=10
TEST_MIN_COUNT_SIT_UP=10
TEST_MIN_COUNT_PUSH_UP=10
